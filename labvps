func determineParam(cfg *Configuration) string {
	if cfg.InjectParam != "" {
		return cfg.InjectParam
	}

	if cfg.Method == "GET" {
		if u, err := url.Parse(cfg.TargetURL); err == nil {
			if query := u.Query(); len(query) > 0 {
				for k := range query {
					return k // return first parameter
				}
			}
		}
	} else if cfg.Method == "POST" && cfg.PostData != "" {
		parts := strings.Split(cfg.PostData, "&")
		if len(parts) > 0 {
			kv := strings.SplitN(parts[0], "=", 2)
			if len(kv) > 0 {
				return kv[0]
			}
		}
	}
	return "" // fallback
}

func worker(ctx context.Context, wg *sync.WaitGroup, payloadChan <-chan string, cfg *Configuration, param string) {
	defer wg.Done()

	for {
		select {
		case <-ctx.Done():
			return
		case payload, ok := <-payloadChan:
			if !ok {
				return
			}
			// Skip empty payloads
			if payload == "" {
				continue
			}
			testInjection(cfg, param, payload)
		}
	}
}

func testInjection(cfg *Configuration, param, payload string) {
	atomic.AddUint64(&requestCount, 1)

	var req *http.Request
	var err error
	var targetURL = cfg.TargetURL
	var body string

	// Encode payload for URL
	encodedPayload := url.QueryEscape(payload)

	if cfg.Method == "GET" {
		// Replace parameter value in URL
		u, err := url.Parse(targetURL)
		if err != nil {
			return
		}
		q := u.Query()
		if q.Has(param) {
			q.Set(param, payload) // keep raw for injection, URL encoding happens automatically
			u.RawQuery = q.Encode()
			targetURL = u.String()
		} else {
			// Append parameter if not present
			if u.RawQuery == "" {
				u.RawQuery = fmt.Sprintf("%s=%s", param, encodedPayload)
			} else {
				u.RawQuery += fmt.Sprintf("&%s=%s", param, encodedPayload)
			}
			targetURL = u.String()
		}
		req, err = http.NewRequest("GET", targetURL, nil)
	} else {
		// POST method
		data := cfg.PostData
		// Replace parameter value
		re := regexp.MustCompile(fmt.Sprintf(`(%s=)[^&]*`, regexp.QuoteMeta(param)))
		data = re.ReplaceAllString(data, fmt.Sprintf("${1}%s", encodedPayload))
		body = data
		req, err = http.NewRequest("POST", targetURL, strings.NewReader(data))
		if req != nil {
			req.Header.Set("Content-Type", "application/x-www-form-urlencoded")
		}
	}

	if err != nil {
		return
	}

	// Set headers
	req.Header.Set("User-Agent", userAgent)
	for _, h := range cfg.Headers {
		parts := strings.SplitN(h, ":", 2)
		if len(parts) == 2 {
			req.Header.Set(strings.TrimSpace(parts[0]), strings.TrimSpace(parts[1]))
		}
	}

	// Retry logic
	var resp *http.Response
	for i := 0; i <= cfg.Retries; i++ {
		resp, err = client.Do(req)
		if err == nil {
			break
		}
		time.Sleep(100 * time.Millisecond)
	}
	if err != nil || resp == nil {
		return
	}
	defer resp.Body.Close()

	// Read response body (limited)
	respBody, err := io.ReadAll(io.LimitReader(resp.Body, 1024*1024)) // 1MB max
	if err != nil {
		return
	}
	bodyStr := string(respBody)

	// Check for SQL errors
	if detectSQLInjection(bodyStr) {
		atomic.AddUint64(&vulnCount, 1)
		resultsMu.Lock()
		results = append(results, Result{
			URL:     targetURL,
			Param:   param,
			Payload: payload,
			Error:   extractFirstError(bodyStr),
		})
		resultsMu.Unlock()

		logVuln(cfg, param, payload, extractFirstError(bodyStr))
	}

	if cfg.Verbose {
		logVerbose(cfg, fmt.Sprintf("Tested: %s = %s [%d]", param, payload, resp.StatusCode))
	}
}

func detectSQLInjection(body string) bool {
	for _, pattern := range sqlErrorPatterns {
		if pattern.MatchString(body) {
			return true
		}
	}
	return false
}

func extractFirstError(body string) string {
	for _, pattern := range sqlErrorPatterns {
		if match := pattern.FindString(body); match != "" {
			return match
		}
	}
	return "SQL error pattern matched"
}

func progressReporter(ctx context.Context, verbose bool) {
	if verbose {
		return
	}
	ticker := time.NewTicker(2 * time.Second)
	defer ticker.Stop()
	for {
		select {
		case <-ctx.Done():
			return
		case <-ticker.C:
			reqs := atomic.LoadUint64(&requestCount)
			vulns := atomic.LoadUint64(&vulnCount)
			fmt.Printf("\r[Progress] Requests: %d | Vulnerabilities: %d", reqs, vulns)
		}
	}
}

func saveResults(cfg *Configuration) {
	// Save vulnerable list
	vulnFile := filepath.Join(cfg.OutputDir, "vulnerable.txt")
	f, err := os.Create(vulnFile)
	if err != nil {
		logError(cfg, fmt.Sprintf("Failed to create results file: %v", err))
		return
	}
	defer f.Close()

	for _, r := range results {
		fmt.Fprintf(f, "URL: %s\nParam: %s\nPayload: %s\nError: %s\n\n", r.URL, r.Param, r.Payload, r.Error)
	}

	// Save full log
	logFile := filepath.Join(cfg.OutputDir, "scan.log")
	// Already using logInfo/logError which write to this file
}

func reportToAPI(cfg *Configuration) {
	if len(results) == 0 {
		return
	}

	type Report struct {
		Target          string   `json:"target"`
		Vulnerabilities []Result `json:"vulnerabilities"`
		Count           int      `json:"count"`
		Scanner         string   `json:"scanner"`
	}

	report := Report{
		Target:          cfg.TargetURL,
		Vulnerabilities: results,
		Count:           len(results),
		Scanner:         "Nanami/" + version,
	}

	jsonData, err := json.Marshal(report)
	if err != nil {
		logError(cfg, fmt.Sprintf("Failed to marshal report: %v", err))
		return
	}

	resp, err := http.Post(cfg.ReportAPI, "application/json", strings.NewReader(string(jsonData)))
	if err != nil {
		logError(cfg, fmt.Sprintf("Failed to send report: %v", err))
		return
	}
	defer resp.Body.Close()
	logInfo(cfg, "Report sent to API successfully")
}

// Logging helpers
func logInfo(cfg *Configuration, msg string) {
	logEntry := fmt.Sprintf("[%s] [INFO] %s\n", time.Now().Format("2006-01-02 15:04:05"), msg)
	fmt.Print(logEntry)
	logToFile(cfg, logEntry)
}

func logError(cfg *Configuration, msg string) {
	logEntry := fmt.Sprintf("[%s] [ERROR] %s\n", time.Now().Format("2006-01-02 15:04:05"), msg)
	fmt.Fprint(os.Stderr, logEntry)
	logToFile(cfg, logEntry)
}

func logVuln(cfg *Configuration, param, payload, errMsg string) {
	logEntry := fmt.Sprintf("[%s] [VULN] Param: %s | Payload: %q | Error: %s\n",
		time.Now().Format("2006-01-02 15:04:05"), param, payload, errMsg)
	fmt.Print(logEntry)
	logToFile(cfg, logEntry)
}

func logVerbose(cfg *Configuration, msg string) {
	if cfg.Verbose {
		logEntry := fmt.Sprintf("[%s] [DEBUG] %s\n", time.Now().Format("2006-01-02 15:04:05"), msg)
		fmt.Print(logEntry)
		logToFile(cfg, logEntry)
	}
}

func logToFile(cfg *Configuration, entry string) {
	logPath := filepath.Join(cfg.OutputDir, "scan.log")
	f, err := os.OpenFile(logPath, os.O_APPEND|os.O_CREATE|os.O_WRONLY, 0644)
	if err != nil {
		return
	}
	defer f.Close()
	f.WriteString(entry)
}
